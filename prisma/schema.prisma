generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Admin / Instance Management
// ============================================

model ServiceNowInstance {
  id                String   @id @default(cuid())
  name              String
  url               String
  username          String
  encryptedPassword String   @map("encrypted_password")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  snapshots         SchemaSnapshot[]

  @@map("servicenow_instances")
}

// ============================================
// AI Model Configuration
// ============================================

enum AIProvider {
  OPENAI
  ANTHROPIC
}

model AIModelConfig {
  id              String     @id @default(cuid())
  name            String
  provider        AIProvider
  baseUrl         String?    @map("base_url")
  modelId         String     @map("model_id")
  encryptedApiKey String     @map("encrypted_api_key")
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@map("ai_model_configs")
}

// ============================================
// Schema Snapshots (versioned)
// ============================================

model SchemaSnapshot {
  id                String             @id @default(cuid())
  label             String
  version           String?
  description       String?
  instanceId        String?            @map("instance_id")
  instance          ServiceNowInstance? @relation(fields: [instanceId], references: [id])
  sourceType        SnapshotSourceType @default(INGESTION) @map("source_type")
  status            SnapshotStatus     @default(PENDING)
  tableCount        Int                @default(0) @map("table_count")
  columnCount       Int                @default(0) @map("column_count")
  ingestStartedAt   DateTime?          @map("ingest_started_at")
  ingestCompletedAt DateTime?          @map("ingest_completed_at")
  errorMessage      String?            @map("error_message")
  isBaseline        Boolean            @default(false) @map("is_baseline")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  tables                 SnapshotTable[]
  catalogSource          CatalogEntry[]          @relation("CatalogSource")
  catalogEntrySnapshots  CatalogEntrySnapshot[]

  @@index([label])
  @@index([isBaseline])
  @@map("schema_snapshots")
}

enum SnapshotSourceType {
  INGESTION
  UPLOAD_JSON
  UPLOAD_CSV
}

enum SnapshotStatus {
  PENDING
  INGESTING_TABLES
  INGESTING_COLUMNS
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================
// Table Metadata
// ============================================

model SnapshotTable {
  id               String         @id @default(cuid())
  snapshotId       String         @map("snapshot_id")
  snapshot         SchemaSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  sysId            String         @map("sys_id")
  name             String
  label            String

  superClassName   String?        @map("super_class_name")

  scopeName        String?        @map("scope_name")
  scopeLabel       String?        @map("scope_label")

  isExtendable     Boolean        @default(true) @map("is_extendable")
  accessibleFrom   String?        @map("accessible_from")
  numberPrefix     String?        @map("number_prefix")

  ownColumnCount   Int            @default(0) @map("own_column_count")
  totalColumnCount Int            @default(0) @map("total_column_count")
  childTableCount  Int            @default(0) @map("child_table_count")

  columns          SnapshotColumn[]

  @@unique([snapshotId, name])
  @@index([snapshotId])
  @@index([superClassName])
  @@index([scopeName])
  @@index([name])
  @@map("snapshot_tables")
}

// ============================================
// Column / Field Metadata
// ============================================

model SnapshotColumn {
  id              String        @id @default(cuid())
  tableId         String        @map("table_id")
  table           SnapshotTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  sysId           String        @map("sys_id")
  element         String
  label           String

  definedOnTable  String        @map("defined_on_table")

  internalType    String        @map("internal_type")

  referenceTable  String?       @map("reference_table")

  maxLength       Int?          @map("max_length")
  isMandatory     Boolean       @default(false) @map("is_mandatory")
  isReadOnly      Boolean       @default(false) @map("is_read_only")
  isActive        Boolean       @default(true) @map("is_active")
  isDisplay       Boolean       @default(false) @map("is_display")
  isPrimary       Boolean       @default(false) @map("is_primary")

  defaultValue    String?       @map("default_value")
  attributes      Json?         @default("{}")

  @@unique([tableId, element])
  @@index([tableId])
  @@index([definedOnTable])
  @@index([element])
  @@index([internalType])
  @@map("snapshot_columns")
}

// ============================================
// Users & Roles
// ============================================

enum UserRole {
  PENDING
  VIEWER
  STEWARD
  ADMIN
}

model User {
  id             String         @id @default(cuid())
  githubId       String         @unique @map("github_id")
  username       String
  displayName    String?        @map("display_name")
  avatarUrl      String?        @map("avatar_url")
  role           UserRole       @default(PENDING)
  approvedById   String?        @map("approved_by_id")
  approvedBy     User?          @relation("ApprovedByAdmin", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedUsers  User[]         @relation("ApprovedByAdmin")
  catalogEntries   CatalogEntry[]
  validatedEntries CatalogEntry[] @relation("ValidatedBy")
  fieldAudits      CatalogFieldAudit[]
  glossaryCreated  GlossaryTerm[] @relation("GlossaryCreatedBy")
  glossaryUpdated  GlossaryTerm[] @relation("GlossaryUpdatedBy")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

// ============================================
// Data Catalog
// ============================================

enum DefinitionSource {
  MANUAL
  SYS_DOCUMENTATION
  EXCEL_UPLOAD
  AI_GENERATED
}

enum ValidationStatus {
  DRAFT
  VALIDATED
}

model CatalogEntry {
  id                     String                 @id @default(cuid())
  tableName              String                 @map("table_name")
  element                String
  label                  String
  internalType           String                 @map("internal_type")
  definition             String?
  definitionSource       DefinitionSource?      @map("definition_source")
  definitionSourceDetail String?                @map("definition_source_detail")
  citationUrl            String?                @map("citation_url")
  validationStatus       ValidationStatus       @default(DRAFT) @map("validation_status")
  validatedAt            DateTime?              @map("validated_at")
  validatedById          String?                @map("validated_by_id")
  validatedBy            User?                  @relation("ValidatedBy", fields: [validatedById], references: [id], onDelete: SetNull)
  stewardId              String?                @map("steward_id")
  steward                User?                  @relation(fields: [stewardId], references: [id], onDelete: SetNull)
  sourceSnapshotId       String                 @map("source_snapshot_id")
  sourceSnapshot         SchemaSnapshot         @relation("CatalogSource", fields: [sourceSnapshotId], references: [id])
  snapshots              CatalogEntrySnapshot[]
  fieldAudits            CatalogFieldAudit[]
  tags                   CatalogEntryTag[]
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")

  @@unique([tableName, element])
  @@index([tableName])
  @@index([element])
  @@index([stewardId])
  @@index([sourceSnapshotId])
  @@index([validationStatus])
  @@map("catalog_entries")
}

model CatalogEntrySnapshot {
  id             String         @id @default(cuid())
  catalogEntryId String         @map("catalog_entry_id")
  catalogEntry   CatalogEntry   @relation(fields: [catalogEntryId], references: [id], onDelete: Cascade)
  snapshotId     String         @map("snapshot_id")
  snapshot       SchemaSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  linkedAt       DateTime       @default(now()) @map("linked_at")

  @@unique([catalogEntryId, snapshotId])
  @@index([catalogEntryId])
  @@index([snapshotId])
  @@map("catalog_entry_snapshots")
}

// ============================================
// Field-Level Audit Trail
// ============================================

model CatalogFieldAudit {
  id             String       @id @default(cuid())
  catalogEntryId String       @map("catalog_entry_id")
  catalogEntry   CatalogEntry @relation(fields: [catalogEntryId], references: [id], onDelete: Cascade)
  fieldName      String       @map("field_name")
  oldValue       String?      @map("old_value")
  newValue       String?      @map("new_value")
  comment        String?
  userId         String?      @map("user_id")
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([catalogEntryId])
  @@index([userId])
  @@map("catalog_field_audits")
}

// ============================================
// Tags
// ============================================

enum TagType {
  AUTO
  USER
}

model Tag {
  id        String            @id @default(cuid())
  name      String            @unique
  color     String            @default("#6B7280")
  tagType   TagType           @default(USER) @map("tag_type")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  entries CatalogEntryTag[]

  @@index([tagType])
  @@map("tags")
}

model CatalogEntryTag {
  id             String       @id @default(cuid())
  catalogEntryId String       @map("catalog_entry_id")
  catalogEntry   CatalogEntry @relation(fields: [catalogEntryId], references: [id], onDelete: Cascade)
  tagId          String       @map("tag_id")
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)
  assignedAt     DateTime     @default(now()) @map("assigned_at")

  @@unique([catalogEntryId, tagId])
  @@index([catalogEntryId])
  @@index([tagId])
  @@map("catalog_entry_tags")
}

// ============================================
// Glossary
// ============================================

model GlossaryTerm {
  id            String   @id @default(cuid())
  term          String   @unique
  definition    String
  category      String?                           // "CSDM Concept", "ServiceNow Concept", "General"
  relatedTables String[] @map("related_tables")   // ServiceNow table names
  csdmDomainId  String?  @map("csdm_domain_id")   // matches CsdmDomain.id slug

  createdById   String?  @map("created_by_id")
  createdBy     User?    @relation("GlossaryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById   String?  @map("updated_by_id")
  updatedBy     User?    @relation("GlossaryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([csdmDomainId])
  @@map("glossary_terms")
}
